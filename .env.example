# Copy to .env and fill in. The docker-compose file reads from this.

# ── Required ──────────────────────────────────────────────────────────────
GATEWAY_ORG_ID=
GATEWAY_MASTER_KEY=                  # openssl rand -base64 32
LITELLM_MASTER_KEY=sk-change-me
GATEWAY_DOMAIN=gateway.yourfirm.com  # must be reachable for ACME

# ── Registry + image tag ──────────────────────────────────────────────────
REGISTRY=ghcr.io/inchambers-ai
IMAGE_TAG=latest

# ── Providers (at least one) ──────────────────────────────────────────────
OPENROUTER_API_KEY=
AZURE_FOUNDRY_URL=
AZURE_FOUNDRY_KEY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ── Optional ──────────────────────────────────────────────────────────────
CADDY_TLS_MODE=auto                  # auto|internal|off
CADDY_ACME_EMAIL=admin@yourfirm.com
ALLOWED_ORIGIN=https://app.inchambers.ai
JWKS_URL=https://app.inchambers.ai/.well-known/jwks.json
ENABLE_REMOTE_REVOCATION_CHECK=false
INCHAMBERS_API=https://app.inchambers.ai
RUST_LOG=ic_gateway_relay=info,tower_http=info
PG_PASSWORD=change-this-too
