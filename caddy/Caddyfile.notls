# Plain-HTTP Caddy config used when the deployment terminates TLS upstream
# (ALB, Cloud Run, Azure Container Apps, an Ingress controller, etc.).
# Caddy listens on :80 only; no ACME, no internal CA, no `tls` directive.
{
	auto_https off
}

:80 {
	# Optional defense-in-depth IP allowlist for the admin console. Unset
	# ADMIN_ALLOW_CIDRS defaults to all IPs (matcher never fires → behavior
	# unchanged). Behind nginx/an LB, `remote_ip` is the proxy peer — do the
	# admin IP restriction at that upstream layer instead.
	@admin_blocked not remote_ip {$ADMIN_ALLOW_CIDRS:0.0.0.0/0 ::/0}

	# CORS: the relay owns CORS on actual (non-OPTIONS) responses via its
	# tower-http CorsLayer (→ Access-Control-Allow-Origin: *). Caddy handles
	# two edge cases the relay can't cover:
	#  1. OPTIONS preflight — answered here so preflights succeed even when
	#     the relay is restarting / unreachable.
	#  2. handle_errors — Caddy-generated 502/503 (relay down) get CORS
	#     headers so the browser exposes the error to JS instead of a
	#     silent CORS block.

	@cors_preflight method OPTIONS
	handle @cors_preflight {
		header Access-Control-Allow-Origin "*"
		header Access-Control-Allow-Methods "*"
		header Access-Control-Allow-Headers "*"
		header Access-Control-Max-Age "86400"
		respond 204
	}

	handle /health {
		header Access-Control-Allow-Origin "*"
		respond "ok" 200
	}

	# Running version (hub-and-spoke updater reads this) → relay.
	handle /version {
		reverse_proxy {$UPSTREAM_RELAY:relay:8081}
	}

	# Anthropic Messages surface for official Claude clients (Claude for
	# M365 "Enterprise gateway", Claude Code, Claude Desktop): the whole bare
	# /v1/* surface (/v1/messages, /v1/messages/count_tokens, /v1/models,
	# /v1/chat/completions) → relay. Must be explicit because the catch-all
	# below now serves the admin console (not the relay).
	handle /v1/* {
		reverse_proxy {$UPSTREAM_RELAY:relay:8081} {
			flush_interval -1
			transport http {
				read_timeout 3600s
				write_timeout 3600s
			}
		}
	}

	# The console used to live under /admin/; it's now at the gateway root.
	# Redirect legacy /admin and /admin/* links to /.
	@admin_legacy path /admin /admin/*
	redir @admin_legacy / permanent

	handle /admin-api/* {
		request_body {
			max_size 64KB
		}
		route {
			respond @admin_blocked "Forbidden" 403
			uri replace /admin-api/ /admin/
			reverse_proxy {$UPSTREAM_RELAY:relay:8081}
		}
	}

	handle /subscription/* {
		uri strip_prefix /subscription
		reverse_proxy {$UPSTREAM_RELAY:relay:8081} {
			flush_interval -1
			transport http {
				read_timeout 3600s
				write_timeout 3600s
			}
		}
	}

	handle /api/tools/* {
		reverse_proxy {$UPSTREAM_RELAY:relay:8081} {
			flush_interval -1
			transport http {
				read_timeout 3600s
				write_timeout 3600s
			}
		}
	}

	# Practice Management (PMA) records → relay. Without this the catch-all below
	# would send /api/pma/* to the admin-ui SPA (200 HTML for GET, 405 for OPTIONS
	# preflight), breaking the add-in's cross-origin PMA calls.
	handle /api/pma/* {
		reverse_proxy {$UPSTREAM_RELAY:relay:8081} {
			flush_interval -1
			transport http {
				read_timeout 3600s
				write_timeout 3600s
			}
		}
	}

	# Client portal API → relay. Covers both the PUBLIC client SSO
	# (/client-api/auth/*) and the require_client-gated client data routes. Must
	# sit above the catch-all or the SPA would serve these as 200 HTML.
	handle /client-api/* {
		reverse_proxy {$UPSTREAM_RELAY:relay:8081}
	}

	# Firm-data relay surfaces that otherwise fall through to the admin-ui SPA:
	#  * /mcp           — the gateway MCP server (Streamable HTTP) that external
	#                     AI clients (Claude Desktop/Code, ChatGPT) connect to.
	#  * /api/memory*    — Firm Memory persist + recall.
	#  * /api/precedents* — Firm Precedent Corpus (index/search/stats).
	#  * /api/embed       — gateway-local embedding model.
	#  * /api/connectors* — org Microsoft connector (search/document).
	#  * /api/platform*   — platform module enable/disable flags.
	#  * /api/usage*      — user quota/usage endpoint (platform gateway).
	#  * /auth/*          — gateway-local member (lawyer) login.
	#  * /connector-oauth/* — accounting connector OAuth callback (browser
	#                     redirect from QuickBooks/Xero/Zoho, no JWT); without
	#                     this the catch-all serves the SPA and consent silently
	#                     fails (200 HTML instead of the relay completing it).
	#  * /api/exit-node*  — residential exit-node WebSocket: the desktop dials it
	#                     to register as the user's egress tunnel. reverse_proxy
	#                     auto-upgrades the WS; without this the catch-all sends
	#                     the upgrade to the SPA and it fails.
	# Without these the catch-all serves them from the platform-ui SPA (200 HTML on
	# GET, 405 on POST), breaking member login, module gating, and connector calls.
	@relay_firmdata path /mcp /mcp/* /api/memory* /api/precedents* /api/embed* /api/connectors* /api/ms/* /api/platform* /api/usage* /api/pipelines* /api/pipeline-events* /api/sync* /api/mcp-servers* /api/exit-node* /auth/* /connector-oauth/*
	handle @relay_firmdata {
		reverse_proxy {$UPSTREAM_RELAY:relay:8081} {
			flush_interval -1
			transport http {
				read_timeout 3600s
				write_timeout 3600s
			}
		}
	}

	handle /anthropic/* {
		reverse_proxy {$UPSTREAM_RELAY:relay:8081} {
			flush_interval -1
			transport http {
				read_timeout 3600s
				write_timeout 3600s
			}
		}
	}

	# Everything else → the unified firm platform SPA at the gateway root (/,
	# /assets/*, client-side routes). All relay/API paths are matched above, so
	# only the UI reaches here. The platform serves both the lawyer-facing PMA
	# and (role-gated) the firm-IT admin sections. Optional IP allowlist applies
	# to the console UI, not the AI surface (which Claude clients hit anywhere).
	handle {
		route {
			respond @admin_blocked "Forbidden" 403
			reverse_proxy {$UPSTREAM_ADMIN:platform-ui:3000}
		}
	}

	handle_errors {
		header Access-Control-Allow-Origin "*"
		header Access-Control-Allow-Methods "*"
		header Access-Control-Allow-Headers "*"
		respond "{err.status_code}" {err.status_code}
	}

	log {
		output stdout
		format json
		level INFO
	}
}
