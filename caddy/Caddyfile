# Caddy reverse proxy for inchambers-gateway.
#
# Path routing:
#   /admin/*              → admin-ui container (SPA)
#   /admin-api/*          → relay (admin endpoints; prefix rewritten to /admin/*)
#   /subscription/*       → relay (subscription-model chat completions)
#   /anthropic/v1/*       → relay (native Anthropic Messages API passthrough)
#   anything else         → LiteLLM (API-key provider routing)
#
# Upstream hostnames are pulled from env so the same Caddyfile works on
# docker-compose (service names `relay`, `litellm`, `admin-ui`) and on
# Kubernetes / Container Apps (fully-qualified service DNS passed in).

{
    email {$CADDY_ACME_EMAIL:admin@inchambers.ai}
}

{$GATEWAY_DOMAIN:localhost} {
    tls {$CADDY_TLS_ISSUER:internal}

    # CORS preflight — match on method; Caddy's header matcher can't glob
    # values, so we only assert the method here.
    @cors_preflight method OPTIONS
    handle @cors_preflight {
        header Access-Control-Allow-Origin "{$ALLOWED_ORIGIN:https://app.inchambers.ai}"
        header Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
        header Access-Control-Allow-Headers "Authorization, Content-Type, X-IC-Client"
        header Access-Control-Max-Age "86400"
        respond "" 204
    }

    header {
        Access-Control-Allow-Origin "{$ALLOWED_ORIGIN:https://app.inchambers.ai}"
        Access-Control-Expose-Headers "X-Request-Id, Retry-After"
    }

    handle /health {
        respond "ok" 200
    }

    handle_path /admin {
        redir /admin/ permanent
    }

    handle /admin/* {
        reverse_proxy {$UPSTREAM_ADMIN:admin-ui:3000}
    }

    # Admin-API: rewrite `/admin-api/...` → `/admin/...` so the relay's
    # `/admin/subscriptions`, `/admin/audit` routes match.
    handle /admin-api/* {
        uri replace /admin-api/ /admin/
        reverse_proxy {$UPSTREAM_RELAY:relay:8081}
    }

    # Subscription-model chat completions: strip `/subscription` and pass
    # to the Rust relay. flush_interval -1 disables buffering for SSE.
    handle /subscription/* {
        uri strip_prefix /subscription
        reverse_proxy {$UPSTREAM_RELAY:relay:8081} {
            flush_interval -1
            transport http {
                read_timeout 3600s
                write_timeout 3600s
            }
        }
    }

    # Native Anthropic Messages API passthrough.
    handle /anthropic/* {
        reverse_proxy {$UPSTREAM_RELAY:relay:8081} {
            flush_interval -1
            transport http {
                read_timeout 3600s
                write_timeout 3600s
            }
        }
    }

    # Default: LiteLLM for API-key providers.
    handle {
        reverse_proxy {$UPSTREAM_LITELLM:litellm:4000} {
            flush_interval -1
            transport http {
                read_timeout 3600s
                write_timeout 3600s
            }
        }
    }

    log {
        output stdout
        format json
        level INFO
    }
}
