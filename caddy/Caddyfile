# Caddy reverse proxy for inchambers-gateway (TLS edge — Caddy terminates TLS).
#
# This MIRRORS caddy/Caddyfile.notls (the config used on the ewarren deploy,
# where nginx terminates TLS and Caddy runs plain-HTTP). Keep the two in sync:
# the ONLY differences here are the `:443` + `tls` directive and the ACME email.
# Routing model (same as notls): the unified platform-ui SPA is served at the
# gateway root; every relay/API surface is matched explicitly ABOVE the catch-all
# (a path that falls through to the catch-all is served the SPA's index.html).
#
# Upstream hostnames come from env so the same Caddyfile works on docker-compose
# (service names `relay`, `platform-ui`) and on Kubernetes / Container Apps.
{
	email {$CADDY_ACME_EMAIL:admin@inchambers.ai}
}

{$GATEWAY_DOMAIN:localhost} {
	tls {$CADDY_TLS_ISSUER:internal}

	# EDGE HARDENING: for production, front this gateway with a WAF / edge
	# rate-limiter (e.g. Cloudflare) — the stock Caddy image has no rate-limit
	# module. The relay rate-limits auth per-IP and /admin-api bodies are capped
	# below, but an edge WAF adds L7 DoS/bot protection.

	# Optional defense-in-depth IP allowlist for the admin console. Unset
	# ADMIN_ALLOW_CIDRS defaults to all IPs (matcher never fires). `remote_ip` is
	# the direct peer — only meaningful when Caddy is the edge; behind nginx/an LB
	# restrict at that layer.
	@admin_blocked not remote_ip {$ADMIN_ALLOW_CIDRS:0.0.0.0/0 ::/0}

	# CORS is owned by the relay (tower-http CorsLayer → `*`). Caddy does NOT
	# inject CORS — a duplicate Access-Control-Allow-Origin would be rejected.

	handle /health {
		# CORS so the inchambers add-in can probe this cross-origin to detect
		# whether a gateway exists at gateway.<firm-domain> (convention routing).
		header Access-Control-Allow-Origin "*"
		respond "ok" 200
	}

	# Running version (hub-and-spoke updater reads this) → relay.
	handle /version {
		reverse_proxy {$UPSTREAM_RELAY:relay:8081}
	}

	# Anthropic Messages surface for official Claude clients (Claude for M365,
	# Claude Code, Claude Desktop): the whole bare /v1/* surface → relay.
	handle /v1/* {
		reverse_proxy {$UPSTREAM_RELAY:relay:8081} {
			flush_interval -1
			transport http {
				read_timeout 3600s
				write_timeout 3600s
			}
		}
	}

	# The console used to live under /admin/; it's now at the gateway root.
	@admin_legacy path /admin /admin/*
	redir @admin_legacy / permanent

	handle /admin-api/* {
		request_body {
			max_size 64KB
		}
		route {
			respond @admin_blocked "Forbidden" 403
			uri replace /admin-api/ /admin/
			reverse_proxy {$UPSTREAM_RELAY:relay:8081}
		}
	}

	handle /subscription/* {
		uri strip_prefix /subscription
		reverse_proxy {$UPSTREAM_RELAY:relay:8081} {
			flush_interval -1
			transport http {
				read_timeout 3600s
				write_timeout 3600s
			}
		}
	}

	handle /api/tools/* {
		reverse_proxy {$UPSTREAM_RELAY:relay:8081} {
			flush_interval -1
			transport http {
				read_timeout 3600s
				write_timeout 3600s
			}
		}
	}

	# Practice Management (PMA) records → relay.
	handle /api/pma/* {
		reverse_proxy {$UPSTREAM_RELAY:relay:8081} {
			flush_interval -1
			transport http {
				read_timeout 3600s
				write_timeout 3600s
			}
		}
	}

	# Client portal API → relay (public client SSO /client-api/auth/* plus the
	# require_client-gated client data routes).
	handle /client-api/* {
		reverse_proxy {$UPSTREAM_RELAY:relay:8081}
	}

	# Firm-data relay surfaces that otherwise fall through to the SPA: gateway MCP,
	# Firm Memory/Precedents/embeddings, org connectors, platform flags, member
	# login (/auth/*), the accounting connector OAuth callback (/connector-oauth/*,
	# a browser redirect from QuickBooks/Xero/Zoho with no JWT), and the exit-node
	# WebSocket. Without these the catch-all serves them from the SPA (200 HTML).
	@relay_firmdata path /mcp /mcp/* /api/memory* /api/precedents* /api/embed* /api/connectors* /api/ms/* /api/platform* /api/pipelines* /api/pipeline-events* /api/sync* /api/mcp-servers* /api/exit-node* /auth/* /connector-oauth/*
	handle @relay_firmdata {
		reverse_proxy {$UPSTREAM_RELAY:relay:8081} {
			flush_interval -1
			transport http {
				read_timeout 3600s
				write_timeout 3600s
			}
		}
	}

	handle /anthropic/* {
		reverse_proxy {$UPSTREAM_RELAY:relay:8081} {
			flush_interval -1
			transport http {
				read_timeout 3600s
				write_timeout 3600s
			}
		}
	}

	# Everything else → the unified firm platform SPA at the gateway root (/,
	# /assets/*, /portal*, client-side routes). All relay/API paths are matched
	# above, so only the UI reaches here.
	handle {
		route {
			respond @admin_blocked "Forbidden" 403
			reverse_proxy {$UPSTREAM_ADMIN:platform-ui:3000}
		}
	}

	log {
		output stdout
		format json
		level INFO
	}
}
